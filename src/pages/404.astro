---
// src/pages/404.astro
import Base from '../layouts/base.astro';
import ContactForm from '../components/ContactForm.astro'
import Head from '../components/Head.astro';
import Hero from '../components/Hero.astro';

---

<!DOCTYPE html>
<html lang="it">
<Head
  title="Pagina non trovata — Il Fisio a Domicilio"
  description="La pagina che cerchi non esiste o è stata spostata."
  page="404"
/>
<Base active="">
  <Hero
    index={false}
    title="Pagina non trovata"
    subtitle="La pagina che cerchi non esiste o è stata spostata."
    breadcrumb="404"
    CTA={false}
  />
  <section class="not-found">
    <div class="not-found-container">
      <p>Puoi tornare alla <a href="/">homepage</a> oppure contattarmi direttamente.</p>
      <div class="not-found-actions">
        <a class="btn btn-md btn-primary" href="/">Torna alla homepage</a>
      </div>
    </div>
  </section>
  <ContactForm />
</Base>
</html>

<style>
  .not-found {
    padding: var(--space-16) 0;
  }

  .not-found-container {
    max-width: 560px;
    margin: 0 auto;
    padding: 0 var(--space-6);
    text-align: center;
  }

  .not-found-container p {
    font-size: 1rem;
    line-height: 1.7;
    color: var(--neutral-700);
    margin-bottom: var(--space-8);
  }

  .not-found-container p a {
    color: var(--primary-800);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .not-found-actions {
    display: flex;
    gap: var(--space-3);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .not-found { padding: var(--space-12) 0; }
    .not-found-actions { flex-direction: column; }
    .not-found-actions .btn { width: 100%; }
  }
</style>