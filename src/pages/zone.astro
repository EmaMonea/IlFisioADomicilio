---
import { Schema } from 'astro-seo-schema';
import { breadcrumb } from '../data/schema.ts';

import Base from '../layouts/base.astro'
import Head from '../components/Head.astro'

import CitiesList from '../components/CitiesList.astro'
import ContactForm from '../components/ContactForm.astro'
import Hero from '../components/Hero.astro'

const locations = [
  {
    title: 'Milano - quartieri ovest',
    cities: ['San Siro', 'Baggio', 'Quinto Romano', 'Figino', 'Trenno', 'Muggiano', 'Gallaratese', 'Forze Armate']
  },
  {
    title: 'Comuni limitrofi',
    cities: ['Pero', 'Rho', 'Cornaredo', 'Corsico', 'Settimo Milanese', 'Cusago', 'Trezzano sul Naviglio', 'Assago', 'Buccinasco']
  },
  {
    title: 'Provincia di Milano - zona ovest',
    cities: ['Pregnana Milanese', 'Vanzago', 'Pogliano Milanese', 'Bareggio', 'Sedriano', 'Vittuone', 'Arluno', 'Corbetta', 'Cisliano', 'Gaggiano']
  }
]
---
<!DOCTYPE html>
<html lang="it">
<Head
    title="Zone servite - Il fisio a domicilio"
    description="Opero a domicilio a Cornaredo, Cusago, Corsico, San Siro, Baggio, Rho, Settimo Milanese, Vittuone, Buccinasco, Trezzano e altri comuni dell'ovest milanese."
    page="zone">
      <Schema slot="head" item={breadcrumb([
        { name: "Home", url: "https://www.ilfisioadomicilio.it" },
        { name: "Zone servite", url: "https://www.ilfisioadomicilio.it/zone" }
      ])} />
</Head>
<Base
	active="index">
    <Hero 
        index={false}
        title="Dove lavoro"
        subtitle="Opero a domicilio nell'ovest milanese. Qui sotto trovi tutti i comuni che raggiungo regolarmente. 
        Se il tuo comune non è presente, contattami: è possibile che possa raggiungerti lo stesso."
        breadcrumb='Zone servite'
        />
    <section class="section">
        {
            locations.map((location) => (
                <CitiesList 
                    title={location.title}
                    cities={location.cities}
                />
            ))
        }     
        <div class="container">
          <div class="highlight" > 
            <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-info-icon lucide-info"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            <span>La tua zona non compare nell'elenco? Contattami lo stesso. Le zone indicate
              sono quelle che copro abitualmente ma valuto ogni situazione.
           </span> 
          </div>
        </div>
    </section>
	
	<ContactForm></ContactForm>
	<style>
    .info-icon {
      width:16px;
      height:16px;
      flex-shrink: 0;
      color: var(--secondary-600);
      align-self: center;
    } 
    .highlight{
      display:flex;
      gap: var(--space-4);
      border: 1px solid var(--secondary-400);
    }
    @media screen and (max-width: 768px){
      .info-icon{
        display:none;
      }
    }

  </style>
</Base>

</html>