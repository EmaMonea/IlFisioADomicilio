---
import { Schema } from 'astro-seo-schema'
import { schemas } from '../data/schema.ts'

import Base from '../layouts/base.astro'
import Head from '../components/Head.astro'

import ChiSono from '../components/Chi_Sono.astro'
import ContactForm from '../components/ContactForm.astro'
import FAQ from '../components/FAQ.astro'
import Hero from '../components/Hero.astro'
import Steps from '../components/Steps.astro'
import Servizi from '../components/Servizi.astro'
import Zones from '../components/Zones.astro'

const faqs = [{
	"data":  [
		{
			question: 'Come funziona la prima visita?',
			answer: 'Durante la prima visita viene effettuata la raccolta dei dati anamnestici, la valutazione iniziale, l\'esame obiettivo e la somministrazione della scale di valutazione. Questo permette la definizione di un punto di partenza e la definizione del piano di trattamento. Dura circa un\'ora.',
		},
		{
			question: 'Serve la prescrizione del medico?',
			answer: 'No. Il fisioterapista è un professionista sanitario con la possibilità di accesso diretto. Puoi contattarmi direttamente senza prescrizione.',
		},
		{
			question: 'Quante sedute servono per il mio problema?',
			answer: 'Dipende dal problema e da altri fattori. Se vuoi saperlo contattami e spiegami il problema: è più probabile che io riesca a darti una risposta più precisa.',
		},
		{
			question: 'Che cosa mi serve per iniziare?',
			answer: 'Un piccolo spazio in cui si può lavorare, un pizzico di collaborazione e un po\' d\'impegno.',
		},
		{
			question: 'Cosa cambia tra fisioterapia in struttura e al domicilio?',
			answer: 'Dipende chi è il paziente e qual è il problema. Nella maggior parte dei casi è una questione di praticità: alcuni strumenti sono difficili da trasportare.',
		},
		{
			question: 'Posso detrarre il costo?',
			answer: 'Sì, per tutte le spese sanitarie oltre l\'importo di 129,11€ annui. Il pagamento deve essere tracciabile.',
		},
	]
	}
];
---
<!DOCTYPE html>
<html lang="it">
<Head
	title="Il fisio a domicilio"
	description="Fisioterapista a domicilio nell'ovest milanese. Riabilitazione post-operatoria, ortopedica, geriatrica, sportiva, neurologica e cardiologica."
	page="index">
		<Schema item={schemas.website}></Schema>
		<Schema item={schemas.homepage}></Schema>
</Head>
<Base
	active="index">
	<Hero index={true}></Hero>
	<Steps></Steps>
	<Servizi></Servizi>
	<Zones></Zones>
	<ChiSono></ChiSono>
	<FAQ 
		faqdata={faqs}
		header="Domande frequenti"
		subtitle="Quello che i pazienti mi chiedono più spesso."
		linkToFaq={true}/>
	<ContactForm></ContactForm>
	
</Base>
</html>