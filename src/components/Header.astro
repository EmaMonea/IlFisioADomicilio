---
import Hamburger from './Hamburger.astro';
import Nav from './Nav.astro';
import NavClaude from './Nav-claude.astro';
/*
    <div class="nav-brand">
        <a href="/" >Il fisio<span> a domicilio</span></a>
    </div>
    <Nav />
    <Hamburger />
 */
---

<header>
    <NavClaude></NavClaude>
     
</header>

<style>
    /*header {
        display: grid;
        grid-template-columns: repeat(2, minmax(10px, 1fr)) repeat(8, minmax(145px, 1fr)) repeat(2, minmax(10px, 1fr));
        padding: 1rem 0 0.25rem 0;
    } */

    .nav-brand {
        height:100%;
        align-content: center;
        grid-column: 3/5;
        font-family: var(--font-display);
        font-size: var(--text-xl);
        color: var(--primary-800);
    }
    
    .nav-brand span { color: var(--primary-500); }
     

    @media screen and (max-width: 1200px) {
        header {
            grid-template-columns: repeat(1, 10px) repeat(8, 1fr) repeat(1, 10px);
        }
        .logo {
            grid-column: 2/5;
        }
    }
    @media screen and (max-width: 768px) {
        .logo {
            min-width: 240px;
            grid-column: 2/8;
        }
    }
</style>