---
import Hamburger from './Hamburger.astro';
import Nav from './Nav.astro';

---

<header>
    <Nav></Nav>
     
</header>

<style>
    header{
        position:sticky;
        z-index:999;
        top:0;
    }
    .nav-brand {
        height:100%;
        align-content: center;
        grid-column: 3/5;
        font-family: var(--font-display);
        font-size: var(--text-xl);
        color: var(--primary-800);
    }
    
    .nav-brand span { color: var(--primary-500); }
     

    @media screen and (max-width: 1200px) {
        header {
            grid-template-columns: repeat(1, 10px) repeat(8, 1fr) repeat(1, 10px);
        }
        .logo {
            grid-column: 2/5;
        }
    }
    @media screen and (max-width: 768px) {
        .logo {
            min-width: 240px;
            grid-column: 2/8;
        }
    }
</style>