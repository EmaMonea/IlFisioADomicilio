---
interface Props {
    title: string,
    cities: string[],   
}
const {title, cities} = Astro.props;

---
<article class="container">
    <h3 class="location-title">{title}</h3> 
    <div class="location-row">
    {
        cities.map((city) => (
            <div class="location-item">
                <svg class="location-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <g clip-path="url(#clip0_59_522)">
                    <path d="M15.75 7.5C15.75 12.75 9 17.25 9 17.25C9 17.25 2.25 12.75 2.25 7.5C2.25 5.70979 2.96116 3.9929 4.22703 2.72703C5.4929 1.46116 7.20979 0.75 9 0.75C10.7902 0.75 12.5071 1.46116 13.773 2.72703C15.0388 3.9929 15.75 5.70979 15.75 7.5Z" stroke="#1A9485" stroke-width="1.5"/>
                    <path d="M9 9.75C10.2426 9.75 11.25 8.74264 11.25 7.5C11.25 6.25736 10.2426 5.25 9 5.25C7.75736 5.25 6.75 6.25736 6.75 7.5C6.75 8.74264 7.75736 9.75 9 9.75Z" stroke="#1A9485" stroke-width="1.5"/>
                    </g>
                    <defs>
                    <clipPath id="clip0_59_522">
                    <rect width="18" height="18" fill="white"/>
                    </clipPath>
                    </defs>
                </svg>
                <span class="location-text">{city}</span>
            </div>
        )) 
    }
    </div>
</article>
<style>
    article{
        margin-bottom: var(--space-8);
    }
    .location-icon{
        width:18px;
        height:18px;
    }
    .location-row{
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap:var(--space-3);
        padding: var(--space-4) 0;
    }
    .location-title{
        font-size: var(--text-sm);
        font-family: var(--font-body);
        text-transform: uppercase;
        letter-spacing: var(--tracking-widest);
        color: var(--neutral-700);
    }
    .location-title::after{
        display:block;
        content:"";
        height:1px;
        width:100%;
        background-color: var(--neutral-100);
        margin-top: var(--space-2);
    }
    .location-item{
        display:flex;
        gap:var(--space-3);
        border:1px solid var(--neutral-200); 
        padding: var(--space-3); 
        border-radius: var(--radius-lg);
        align-items: center;
        transition: all 0.1s ease;
    }
    .location-item:hover{
        border-color: var(--primary-300);
        background: var(--primary-50); 
        box-shadow: var(--shadow-sm);
    }
    .location-text{
        font-family: var(--font-body);
        font-weight: var(--weight-semibold);
        color: var(--neutral-900);
    }
</style>