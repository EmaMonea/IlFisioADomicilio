---
// src/components/Steps.astro
---
 
<section class="section" aria-labelledby="steps-heading">
  <div class="container">
    <header class="section-header">
      <p class="section-label">Come funziona</p>
      <h2 class="section-title">In pratica</h2>
    </header>
 
    <ol class="steps-list" role="list">
 
      <li class="step">
        <div class="step-icon" aria-hidden="true">
          <!-- lucide: message-square -->
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/>
          </svg>
        </div>
        <h3 class="step-title">Contattami</h3>
        <p class="step-text">Verifichiamo insieme se il fisioterapista è la figura che cerchi.</p>
      </li>
 
      <li class="step">
        <div class="step-icon" aria-hidden="true">
          <!-- lucide: home -->
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </div>
        <h3 class="step-title">Valutazione a casa tua</h3>
        <p class="step-text">Definiamo un punto di partenza. La valutazione iniziale è fondamentale per stabilire un percorso di trattamento.</p>
      </li>
 
      <li class="step">
        <div class="step-icon" aria-hidden="true">
          <!-- lucide: activity -->
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
          </svg>
        </div>
        <h3 class="step-title">Percorso di cura</h3>
        <p class="step-text">Si parte con un piano di trattamento strutturato che ha obiettivi precisi. A questo punto saranno chiari tempistiche e frequenza. </p>
      </li>
 
    </ol>
 
  </div>
</section>
 
<style>
 
  /* ── Header ── */
  .steps-header {
    text-align: center;
    max-width: 580px;
    margin: 0 auto 48px;
  }
  
 
  /* ── Lista step ── */
  .steps-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: step;
  }
 
  /* ── Singolo step ── */
  .step {
    text-align: center;
    counter-increment: step;
  }
 
  .step-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    border-radius: 50%;
    background: var(--primary-50);
    border: 1.5px solid var(--primary-200);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-600);
  }
 
  .step-title {
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--neutral-800);
    margin-bottom: 12px;
  }
 
  .step-title::before {
    content: counter(step) ". ";
    color: var(--primary-500);
  }
 
  .step-text {
    font-size: 1rem;
    color: var(--neutral-700);
    line-height: 1.65;
    max-width: 300px;
    margin: 0 auto;
  }
 /* ── Hover ── */
.step-icon {
  transition: transform 0.25s ease, background 0.25s ease;
}

.step-icon:hover {
  transform: scale(1.08);
  background: var(--primary-100);
  border-color: var(--primary-400);
}

/* ── Scroll animation ── */
.step {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s ease, transform 0.5s ease;
}

.step.visible {
  opacity: 1;
  transform: translateY(0);
}

.step:nth-child(2) { transition-delay: 0.1s; }
.step:nth-child(3) { transition-delay: 0.2s; }

@media (prefers-reduced-motion: reduce) {
  .step {
    opacity: 1;
    transform: none;
    transition: none;
  }
}
  /* ── Tablet ── */
  @media (max-width: 900px) {
    .steps { padding: 64px 0; }
 
    .steps-list {
      grid-template-columns: 1fr;
      gap: 36px;
      max-width: 400px;
      margin: 0 auto;
    }
  }
 
  /* ── Mobile ── */
  @media (max-width: 640px) {
    .steps { padding: 48px 0; }
    .steps-header { margin-bottom: 36px; }
    .steps-list { gap: 28px; }
    .step-text { max-width: none; }
  }
</style>
<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.2 }
  );

  document.querySelectorAll('.step').forEach(el => observer.observe(el));
</script>