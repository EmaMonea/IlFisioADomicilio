---
interface Props {
    index: boolean;
    title?: string;
    subtitle?: string;
    breadcrumb?: string;
    CTA?: boolean;
}
const {index, title, subtitle, breadcrumb, CTA} = Astro.props;


---
{
  (index) ? 
    <section class="hero">   
        <div class="hero-content">
            <h1>La fisioterapia viene <span>a casa tua.</span></h1>
            <h2>Sedute riabilitative direttamente a domicilio nell'ovest Milanese.
                Senza spostamenti, senza attese.
            </h2>
            <div class="hero-cta">
                <a class="btn btn-md btn-secondary" href="tel:+393395721209">Chiama ora</a>
                <a class="btn btn-md btn-hero-outline" href="#servizi"> Scopri i servizi</a>
            </div>
            <div class="hero-trust">
                <div class="hero-trust-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-check-icon lucide-check">
                        <path d="M20 6 9 17l-5-5"/>
                    </svg>
                    Nessuna prescrizione richiesta
                </div>
                <div class="hero-trust-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clock-icon lucide-clock"><circle cx="12" cy="12" r="10"/>
                        <path d="M12 6v6l4 2"/>
                    </svg>
                    Risposta tempestiva
                </div>
            </div>
        </div>
        <div class="hero-visual">

        </div>
    </section>
    :
    <section class="hero section section-alt">
        <div class="hero-content container">
            <div class="breadcrumb">
                <a href="/">Home</a>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                <span>{breadcrumb}</span>
            </div>
            <h1 >{title}</h1>
            {subtitle &&<h2 >{subtitle}</h2>}
            <div class=`hero-cta ${(!CTA) ? "hidden" : "not-hidden"}`>
                <a class="btn btn-md btn-primary" href="#contatti">Contattami</a> 
            </div>
        </div>
    </section>
}

{ (index) ?    
<style>

    .hero {
        color: var(--neutral-50);
        display: grid;
        grid-column: 1/-1;
        grid-template-columns:repeat(2,minmax(10px,1fr)) repeat(8,minmax(145px,1fr)) repeat(2,minmax(10px,1fr));
        overflow: hidden;
        background: linear-gradient(160deg,var(--primary-900) 0%,var(--primary-700) 55%,var(--primary-600) 100%);
        padding: var(--space-20) var(--space-6);
        position:relative; 
        max-width: 100vw;        
    }
    .hero::before {
        content: '';
        position: absolute;
        top: -200px;
        right: -150px;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: rgba(255,255,255,0.03);
    }
    .hero::after {
        content: '';
        position: absolute;
        bottom: -300px;
        left: -100px;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: rgba(93,203,185,.06);
    }
    
    /* Left side column of the hero */
    .hero-content {
        grid-column: 3/7;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        z-index: 1;
        padding: var(--space-12) var(--space-6);   
     }
    .hero h1 {
        font-family: var(--font-display);
        font-size: clamp(2.2rem,5vw,3.2rem);
        line-height: 1.15;
        margin-bottom: 20px;
        letter-spacing: -.01em; 
    }
    .hero h2 {
        font-size: 1.125rem;
        line-height: 1.65;
        opacity: .85;
        margin-bottom: 36px;
        font-weight: 300;
    }
    .hero h1 > span {
        color: var(--primary-200);
    }
    .hero-cta {
        display:flex;
        gap: var(--space-4);
        width: 100%;
    }
    .hero-trust{
        display:flex;
        flex-wrap: wrap;
        gap: var(--space-8);
    }
    .hero-trust-item svg {
        position:relative;
        bottom:-2px;
        height:1.1rem;
    }
    
    /* Right side column of the hero */
    .hero-visual{
        background-color: rgba(255, 255, 255, 0.2);
        border-radius: var(--radius-2xl);
        border: 1px solid var(--primary-100);
        grid-column: span 4; 
        margin:0 var(--space-12);
        min-width:200px;
    }
    @media screen and (max-width: 1200px) {
        .hero{
            grid-template-columns:repeat(2,10px) repeat(8, minmax(80px, 1fr)) repeat(2, 10px);
            padding: var(--space-20) var(--space-2);
        }
        .hero-content{
            display:flex;
            padding:var(--space-12) var(--space-2) var(--space-12) 0;
        }
        .hero-visual{
            margin:0 clamp(1vw, 2.5vw, 2vw); 
        }
    }
    @media screen and (max-width: 768px) {
        .hero{
            display:flex;
            flex-direction: column-reverse;
            padding: var(--space-20) clamp(1rem, 3vw, 1.5rem);
            justify-content: center;
            align-items: center;
        }
        .hero-content{
            display:flex;
            padding:var(--space-12) 0;
            max-width:clamp(95vw, 70vw, 80vw);
            text-align: center;
            align-items: center;
            justify-content: center;
        }
        .hero-content h2 {
            margin-bottom:0;
        }
        .hero-visual{
            margin:0 clamp(1vw, 2.5vw, 2vw); 
        }
        .hero-cta{
            display:flex;
            flex-wrap: wrap;
            width:fit-content;            
            justify-content: center;            
        }
        .hero-trust{
            justify-content: center;
        }
    }
</style>
 :
 <style>  
    .breadcrumb {
        font-size: var(--text-sm);
        color: var(--neutral-500);
        margin-bottom: var(--space-4);
        display: flex;
        gap: 6px;
    }
    .hero {
        display:flex;
        flex-direction: column; 
        align-items: center;
    }
    .hero-content{
        width:100%;
        max-width:1200px;
        padding: 0 var(--space-6); 
    }
    .hero h1 {
        font-family: var(--font-display);
        font-size: clamp(2.2rem,5vw,3.2rem);
        color: var(--primary-800);
    }
    .hero h2 {
        font-family: var(--font-body);
        font-size: var(--text-md);
        color: var(--neutral-800);        
        margin-bottom: var(--space-8);
        font-weight: 300; 
    }
    .hero-cta {
        display:flex;
        gap: var(--space-4);
        width: 100%;
    }
    .hidden{
        display:none;
    }
    @media screen and (max-width: 768px){
        .hero-content{
            align-items: center;
            justify-content: center;
        }
    }
    </style> 
}