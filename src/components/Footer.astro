<style>
    a {
        text-decoration: none;
        color: #b3b3b3;
    }
    footer {
        background-color:var(--neutral-950);
        padding: 2.5rem 0px; 
        color: white;
        display: grid;
        grid-template-columns: repeat(2, minmax(10px, 1fr)) repeat(8, minmax(145px, 1fr)) repeat(2, minmax(10px, 1fr));
    }
    footer h3 {
        font-family: var(--font-body);
        font-size: var(--text-base);
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #b3b3b3;
        font-weight: 500;
    }
    section {
        grid-column: 3 / span 8;
        display: grid;
        grid-template-columns: subgrid;
        margin-bottom: 30px;
    }

    ul {
        list-style-type: none;
    }
    ul > li {
        margin-top: var(--space-2);
    }

    /* left column css */

    .colonna-sx {
        grid-column: span 3;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    
    .footer-branding{

    }
    .footer-description{
        margin-top: var(--space-2);
    }    
    .logo-bianco {
        display: block;
        max-width: 100%;
        font-size: 1.5rem;
        font-family: var(--font-display);
        font-weight: var(--weight-light);
    }

    /* right column css */

    .colonna-dx {
        display: flex;
        justify-content: space-between;
        grid-column: 5 / span 5;
    }
    .colonna-dx h3 {
        margin-bottom: 1em;
    }
    .categoria {
        line-height: 1.7em;
    }
    
    .section-bottom {
        font-size: 1em;
        display: block;
        color: #b3b3b3;
        display: flex;
        justify-content: space-between;
    }

    /*---------------------Footer links-------------------------*/

    .map-link {
        text-decoration: none;
        color: white;
    }

    @media screen and (max-width: 1200px) {
        footer {
            padding: 2em;
            display: flex;
            flex-direction: column;
        }
        .section-top {
            flex-wrap:wrap;
        }

        /* left column media */
        .colonna-sx {
            justify-content: space-between;
            margin-bottom: 1rem;
        }
        .footer-branding{
            margin-bottom:2rem;
        }
        .footer-contatti{
            text-wrap: nowrap;
        }

        /* right column media */
        .colonna-dx {
            margin-left:var(--space-4);
            gap:var(--space-2);
        }

        .section-bottom {
            padding-right: 0 6em;
        }

        .sec-bottom-sx {
            padding-right: 2em;
        }

        .sec-bottom-dx {
            padding-left: 2em;
            text-align: right;
        }
        

        
    }

    @media screen and (max-width: 800px) {
        .section-top{
            display:flex;
        }
        .colonna-sx{
            display: flex;
            flex-direction: row;
            margin-bottom: 2rem;
            align-items: end;
            width: 100%;
            flex-wrap: wrap;
            justify-content: space-between;
            gap:1rem;
        }
        .footer-branding { margin:0;}
        .colonna-dx{
            width:100%;
            align-items: space-between;
            margin-left:0;            
            flex-wrap:wrap;
            gap:25px;
        }
    }

</style>