---
// src/components/Contact.astro
---

<section class="contact" id="contatti" aria-labelledby="contact-heading">
  <div class="contact-container">

    <div class="contact-info">
      <h2 id="contact-heading">Parliamone. </h2>
      <p class="contact-intro">Scegli il canale che preferisci. Ti rispondo personalmente, di solito in giornata.</p>

      <ul class="contact-channels" role="list">
        <li>
          <a class="channel" href="tel:+393395721209">
            <span class="channel-label">Telefono</span>
            <span class="channel-value">339 572 1209</span>
            <span class="channel-note">Lun–Ven 9–18</span>
          </a>
        </li>
        <li>
          <a class="channel" href="https://wa.me/393395721209?text=Ciao%2C%20vorrei%20informazioni%20sulla%20fisioterapia%20a%20domicilio" target="_blank" rel="noopener">
            <span class="channel-label">WhatsApp</span>
            <span class="channel-value">Scrivimi un messaggio</span> 
          </a>
        </li>
        <li>
          <a class="channel" href="mailto:info@emanuelemonea.it">
            <span class="channel-label">Email</span>
            <span class="channel-value">info@emanuelemonea.it</span> 
          </a>
        </li>
      </ul>
    </div>

    <form class="contact-form" id="contact-form">

  <!-- Honeypot -->
  <input type="checkbox" name="I_Accept_The_Terms_And_Conditions" value="yes" tabindex="-1" autocomplete="off" class="hp">

  <h3 class="form-title">Lasciami un messaggio</h3>
  <p class="form-subtitle">Ti richiamo in giornata.</p>

  <!-- Formspark: redirect disabilitato, risposta JSON -->
  <input type="hidden" name="_redirect" value="false">

  <div class="field">
    <label for="name">Nome e cognome</label>
    <input type="text" id="name" name="name" autocomplete="name" required minlength="2" maxlength="100" placeholder="Mario Rossi">
  </div>

  <div class="field">
    <label for="phone">Telefono</label>
    <input type="tel" id="phone" name="phone" autocomplete="tel" required minlength="6" maxlength="20" pattern="[\d\s\+\-()]+" placeholder="333 1234567">
  </div>

  <div class="field">
    <label for="message">Descrivi brevemente la situazione</label>
    <textarea id="message" name="message" rows="4" maxlength="500" placeholder="Es. dolore alla spalla dopo intervento, mia madre ha difficoltà a camminare..."></textarea>
  </div>

  <div class="submit-container">
    <button type="submit" class="form-submit" id="form-submit">Invia richiesta</button>
    <p class="form-status" id="form-status" aria-live="polite"></p>
  </div>
  <p class="form-privacy">I dati che lasci servono solo a ricontattarti. Nessun altro utilizzo. <a href="/privacy">Privacy policy</a></p>
</form>

  </div>
</section>

<style>
  /* ── Sezione ── */
  .contact {
    padding: 80px 0;
    background: linear-gradient(160deg, var(--primary-900) 0%, var(--primary-800) 100%);
    color: var(--white);
    position:relative;
    overflow:hidden;
  }
    .contact::before {
        content: '';
        position: absolute;
        top: -200px;
        right: -150px;
        width: 600px;
        height: 600px;
        border-radius: 50%;
        background: rgba(255,255,255,0.03);
    }
    .contact::after {
        content: '';
        position: absolute;
        bottom: -300px;
        left: -100px;
        width: 500px;
        height: 500px;
        border-radius: 50%;
        background: rgba(93,203,185,.06);
    }
     
  .contact-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* ── Info ── */
  .contact-info h2 {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    line-height: 1.3;
    margin-bottom: 12px;
  }

  .contact-intro {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--primary-50);
    margin-bottom: 36px;
  }

  /* ── Canali ── */
  .contact-channels {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .channel {
    display: block;
    padding: 18px 20px;
    border-radius: 12px;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.1);
    text-decoration: none;
    color: var(--white);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .channel:hover {
    background: rgba(255,255,255,0.14);
    border-color: rgba(255,255,255,0.2);
  }

  .channel:focus-visible {
    outline: 2px solid var(--white);
    outline-offset: 2px;
    border-radius: 12px;
  }

  .channel-label {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .channel-value {
    display: block;
    font-size: 1rem;
    color: var(--primary-50);
  }

  .channel-note {
    display: block;
    font-size: 1rem;
    color: var(--primary-50);
    margin-top: 4px;
  }

  /* ── Form card ── */
  .contact-form {
    background: var(--white);
    border-radius: 20px;
    padding: 36px;
    color: var(--neutral-900);
  }

  .form-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--neutral-900);
    margin-bottom: 4px;
  }

  .form-subtitle {
    font-size: 1rem;
    color: var(--neutral-700);
    margin-bottom: 24px;
  }

  /* ── Campi ── */
  .field {
    margin-bottom: 16px;
  }

  .field label {
    display: block;
    font-size: 1rem;
    font-weight: 500;
    color: var(--neutral-700);
    margin-bottom: 6px;
  }

  .field input,
  .field textarea {
    width: 100%;
    font-family: inherit;
    font-size: 1rem;
    padding: 12px 16px;
    border: 1.5px solid var(--neutral-200);
    border-radius: 8px;
    background: var(--white);
    color: var(--neutral-900);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field input {
    min-height: 48px;
  }

  .field textarea {
    min-height: 100px;
    resize: vertical;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: var(--neutral-400);
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--primary-500);
    box-shadow: 0 0 0 3px var(--primary-100);
  }
  .submit-container{
    padding:0;
    height: 52px;
    overflow: hidden;
  }

  /* ── Submit ── */
  .form-submit {
    width: 100%;
    padding: 8px;
    min-height: 50px;
    border: none;
    border-radius: 12px;
    background: var(--primary-700);
    color: var(--white);
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .form-submit:hover {
    background: var(--primary-800);
  }

  .form-submit:focus-visible {
    outline: 2px solid var(--primary-500);
    outline-offset: 4px;
  }
  /*  Status */ 
   .hp {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    pointer-events: none;
  }

  .field-error {
    font-size: 1rem;
    color: var(--error-600);
    margin-top: var(--space-1);
    min-height: 0;
  }

  .form-status {
    font-size: 1rem;
    text-align: center;
    margin-top: var(--space-4);
    min-height: 0;
  }

  .form-status.success { color: var(--success-600); }
  .form-status.error { color: var(--error-600); }

  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .sent{
    display:none;
  }
  /* ── Privacy ── */
  .form-privacy {
    font-size: 1rem;
    color: var(--neutral-700);
    text-align: center;
    margin-top: 16px;
    line-height: 1.5;
  }

  .form-privacy a {
    color: var(--primary-700);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .form-privacy a:focus-visible {
    outline: 2px solid var(--primary-500);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ── Scroll animation ── */
  .contact-info,
  .contact-form {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .contact-form {
    transition-delay: 0.1s;
  }

  .contact-info.visible,
  .contact-form.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Tablet ── */
  @media (max-width: 900px) {
    .contact { padding: 64px 0; }

    .contact-container {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .contact { padding: 48px 0; }
    .contact-form { padding: 24px 20px; }
    .contact-intro { margin-bottom: 28px; }
  }

  /* ── Accessibilità ── */
  @media (prefers-reduced-motion: reduce) {
    .contact-info,
    .contact-form {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .channel { transition: none; }
    .form-submit { transition: none; }
    .field input, .field textarea { transition: none; }
  }

  @media (hover: none) {
    .channel:hover {
      background: rgba(255,255,255,0.08);
      border-color: rgba(255,255,255,0.1);
    }
    .form-submit:hover {
      background: var(--primary-700);
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll('.contact-info, .contact-form').forEach(el => observer.observe(el));
</script>
<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('form-submit') as HTMLButtonElement;
  const status = document.getElementById('form-status') as HTMLElement;
  const phoneInput = document.getElementById('phone') as HTMLInputElement;
  const phoneError = document.getElementById('phone-error') as HTMLElement;

  // Sanitize: rimuove tag HTML
  function clean(str: string): string {
    return str.replace(/<[^>]*>/g, '').trim();
  }

  // Validazione telefono
  

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Honeypot check
    const hp = form.querySelector<HTMLInputElement>('input[name="I_Accept_The_Terms_And_Conditions"]');
    if (hp?.checked) return;

    // Validazione
    const name = clean((form.querySelector('#name') as HTMLInputElement).value);
    const phone = clean(phoneInput.value);
    const message = clean((form.querySelector('#message') as HTMLTextAreaElement).value);
    const digits = phone.replace(/\D/g, '');

    if (name.length < 2) {
      status.textContent = 'Inserisci il tuo nome.';
      status.className = 'form-status error';
      return;
    }

    if (digits.length < 6) {
      phoneError.textContent = 'Inserisci un numero di telefono valido.';
      return;
    }

    // UI: loading
    submitBtn.textContent = 'Invio in corso...';
    submitBtn.disabled = true;
    status.textContent = '';
    status.className = 'form-status';

    try {
      const res = await fetch('https://submit-form.com/VrSSCjcHx', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
        },
        body: JSON.stringify({
          name,
          phone,
          message,
          _redirect: false,
        }),
      });

      if (res.ok) {
        status.textContent = 'Richiesta inviata. Ti richiamo in giornata.';
        status.className = 'form-status success';
        submitBtn.classList.add('sent');
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      status.textContent = 'Errore nell\'invio. Prova a chiamarmi direttamente.';
      status.className = 'form-status error';
      submitBtn.textContent = 'Invia richiesta';
      submitBtn.disabled = false;
    }
  });
</script>