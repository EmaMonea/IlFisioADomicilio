---
// src/components/Services.astro
const services = [
  {
    href: '/servizi/riabilitazione-post-operatoria',
    title: 'Riabilitazione post-operatoria',
    text: 'Dopo un intervento il recupero va iniziato il prima possibile rispettando le indicazioni ortopediche. Il recupero dell\'articolarità e della forza sono i primi passi verso l\'autonomia.',
    icon: 'trending-up',
  },
  {
    href: '/servizi/riabilitazione-ortopedica',
    title: 'Fisioterapia ortopedica',
    text: 'Lombalgia e cervicalgia sono le problematiche più comuni. Richiedono una corretta dose di 3 ingredienti: terapia manuale, esercizio riabilitativo ed educazione.',
    icon: 'knee',
  },
  {
    href: '/servizi/riabilitazione-geriatrica',
    title: 'Fisioterapia geriatrica',
    text: 'Il paziente geriatrico richiede capacità di gestione a 360° perchè spesso più fragile. L\'obiettivo è il recupero dell\'autonomia nelle attività quotidiane: camminare, vestirsi, gestire la propria igiene.',
    icon: 'heart',
  },
  {
    href: '/servizi/riabilitazione-sportiva',
    title: 'Fisioterapia sportiva',
    text: 'Strappi muscolari, distorsioni, tendiniti. Si lavora sul recupero funzionale e sulla riatletizzazione per un ritorno all\'attività in sicurezza.',
    icon: 'ball',
  },
  {
    href: '/servizi/riabilitazione-neurologica',
    title: 'Fisioterapia neurologica',
    text: 'Riabilitazione dopo ictus e per patologie come sclerosi multipla e Parkinson.',
    icon: 'brain',
  },
  {
    href: '/servizi/riabilitazione-cardiologica',
    title: 'Riabilitazione cardiologica',
    text: 'Recupero della capacità funzionale dopo un evento cardiaco o un intervento. Esercizio aerobico e rinforzo muscolare dosati e monitorati.',
    icon: 'activity',
  },
];
---

<section id="servizi" class="services" aria-labelledby="services-heading">
  <div class="services-container">

    <header class="section-header">
      <p class="section-label">Servizi</p>
      <h2 class="section-title">Cosa posso fare per te</h2>
    </header>

    <ul class="services-grid" role="list">
      {services.map((s, i) => (
        <li class="service-card" style={`--delay: ${i * 0.08}s`}>
          <div class="service-icon" aria-hidden="true">
            {s.icon === 'trending-up' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>
                <polyline points="17 6 23 6 23 12"/>
              </svg>
            )}
            {s.icon === 'knee' && (
              <svg  width="40" height="40" viewBox="0 0 363 421" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <g transform="translate(0,421) scale(0.1,-0.1)">
                  <path d="M2496 3735 c-301 -401 -476 -749 -476 -950 0 -90 18 -145 109 -326 114 -227 120 -330 27 -436 -90 -103 -293 -141 -493 -93 -276 66 -419 268 -382 537 26 190 96 294 356 531 124 112 138 131 383 494 180 268 193 289 182 313 -8 18 -19 25 -40 25 -30 0 -47 -23 -376 -515 -60 -89 -108 -146 -186 -220 -282 -269 -332 -331 -387 -490 -25 -72 -27 -93 -27 -215 0 -122 2 -141 27 -203 53 -136 136 -225 272 -292 112 -56 209 -78 345 -78 302 0 484 140 483 373 -1 95 -21 156 -119 354 -90 182 -97 220 -66 345 51 198 219 496 456 806 42 55 76 103 76 108 0 25 -23 47 -49 47 -25 0 -40 -15 -115 -115z"/>
                  <path d="M1195 2969 c-37 -30 -101 -128 -147 -225 -72 -153 -99 -320 -78 -474 6 -47 16 -91 22 -97 15 -19 52 -16 72 6 14 16 15 25 5 72 -15 68 -6 243 16 324 22 82 84 208 140 284 51 69 57 108 18 122 -16 6 -29 2 -48 -12z"/>
                  <path d="M1387 2312 c-28 -30 -20 -56 37 -119 101 -111 247 -167 436 -167 128 0 173 13 178 52 7 46 -10 51 -136 45 -207 -10 -331 39 -444 175 -30 36 -48 40 -71 14z"/>
                  <path d="M1057 1994 c-37 -25 -71 -52 -74 -61 -14 -36 98 -376 177 -540 42 -87 65 -119 145 -203 54 -57 114 -133 139 -177 80 -136 150 -344 185 -549 10 -62 22 -117 25 -123 12 -19 64 -13 76 9 20 37 -28 278 -94 469 -63 183 -141 313 -263 438 -110 112 -171 236 -258 525 -31 101 -32 108 -16 122 25 23 31 21 86 -25 334 -277 716 -333 1041 -153 33 19 63 34 67 34 8 0 -57 -203 -93 -289 -101 -245 -134 -525 -84 -718 32 -129 138 -293 188 -293 27 0 46 18 46 42 0 10 -18 42 -41 70 -84 107 -119 220 -119 387 0 176 17 248 135 576 48 133 87 285 80 312 -7 31 -32 53 -59 53 -13 0 -57 -22 -98 -49 -141 -93 -262 -131 -424 -131 -209 0 -423 91 -607 258 -37 34 -73 62 -80 62 -7 0 -43 -21 -80 -46z"/>
                  <path d="M1921 1261 c-27 -27 -36 -93 -35 -246 0 -119 7 -174 35 -278 11 -41 42 -61 71 -46 26 14 29 39 12 99 -21 76 -30 299 -15 385 12 67 12 70 -9 87 -28 23 -36 22 -59 -1z"/>
                </g>
              </svg>
            )}
            {s.icon === 'heart' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
              </svg>
            )}
            {s.icon === 'ball' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-volleyball-icon lucide-volleyball"><path d="M11.1 7.1a16.55 16.55 0 0 1 10.9 4"/><path d="M12 12a12.6 12.6 0 0 1-8.7 5"/><path d="M16.8 13.6a16.55 16.55 0 0 1-9 7.5"/><path d="M20.7 17a12.8 12.8 0 0 0-8.7-5 13.3 13.3 0 0 1 0-10"/><path d="M6.3 3.8a16.55 16.55 0 0 0 1.9 11.5"/><circle cx="12" cy="12" r="10"/></svg>
            )}
            {s.icon === 'brain' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-brain-icon lucide-brain"><path d="M12 18V5"/><path d="M15 13a4.17 4.17 0 0 1-3-4 4.17 4.17 0 0 1-3 4"/><path d="M17.598 6.5A3 3 0 1 0 12 5a3 3 0 1 0-5.598 1.5"/><path d="M17.997 5.125a4 4 0 0 1 2.526 5.77"/><path d="M18 18a4 4 0 0 0 2-7.464"/><path d="M19.967 17.483A4 4 0 1 1 12 18a4 4 0 1 1-7.967-.517"/><path d="M6 18a4 4 0 0 1-2-7.464"/><path d="M6.003 5.125a4 4 0 0 0-2.526 5.77"/></svg>
            )}
            {s.icon === 'activity' && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-activity-icon lucide-activity"><path d="M22 12h-2.48a2 2 0 0 0-1.93 1.46l-2.35 8.36a.25.25 0 0 1-.48 0L9.24 2.18a.25.25 0 0 0-.48 0l-2.35 8.36A2 2 0 0 1 4.49 12H2"/></svg>
            )}
          </div>
          <h3 class="service-title">{s.title}</h3>
          <p class="service-text">{s.text}</p>
          <a class="service-link" href={s.href}>
            Scopri di più
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12"/>
              <polyline points="12 5 19 12 12 19"/>
            </svg>
          </a>
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  /* ── Sezione ── */
  .services {
    padding: 80px 0;
    background: var(--neutral-50);
  }

  .services-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }
 

  /* ── Griglia ── */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* ── Card ── */
  .service-card {
    background: var(--white);
    border: 1px solid var(--neutral-150);
    border-radius: 16px;
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--primary-400);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }

  .service-card:hover {
    box-shadow: 0 10px 15px -3px rgba(26,25,23,0.08);
    transform: translateY(-3px);
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  /* ── Icona ── */
  .service-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--primary-50);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary-700);
    margin-bottom: 20px;
    transition: background 0.25s ease;
  }

  .service-card:hover .service-icon {
    background: var(--primary-100);
  }

  /* ── Testi ── */
  .service-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--neutral-900);
    margin-bottom: 8px;
  }

  .service-text {
    font-size: 1rem;
    line-height: 1.65;
    color: var(--neutral-700);
    margin-bottom: 20px;
  }

  /* ── Link ── */
  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 1rem;
    font-weight: 500;
    color: var(--primary-700);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .service-link:hover {
    gap: 10px;
  }

  .service-link:focus-visible {
    outline: 2px solid var(--primary-500);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* ── Scroll animation ── */
  .service-card {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.5s ease var(--delay, 0s),
      transform 0.5s ease var(--delay, 0s),
      box-shadow 0.3s ease,
      transform 0.3s ease;
  }

  .service-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .service-card.visible:hover {
    transform: translateY(-3px);
  }

  /* ── Tablet ── */
  @media (max-width: 900px) {
    .services { padding: 64px 0; }

    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .services { padding: 48px 0; }
    .services-header { margin-bottom: 36px; }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .service-card { padding: 24px 20px; }
  }

  /* ── Accessibilità ── */
  @media (prefers-reduced-motion: reduce) {
    .service-card {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .service-card::before { transition: none; }
    .service-icon { transition: none; }
    .service-link { transition: none; }
  }

  @media (hover: none) {
    .service-card:hover {
      transform: none;
      box-shadow: none;
    }
    .service-card:hover::before {
      transform: scaleX(0);
    }
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll('.service-card').forEach(el => observer.observe(el));
</script>