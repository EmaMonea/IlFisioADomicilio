<button type="button" class="ham-menu" aria-expanded="false" aria-controls="primary-nav" aria-label="Navigation Menu">
    <span></span>
    <span></span>
    <span></span>
</button>
<nav id="primary-nav" class="hidden-menu" aria-label="Mobile navigation">
    <ul>
        <li><a href="/">Servizi</a></li>
        <li><a href="/zone/">Zone</a></li>
        <li><a href="/chi_sono/">Chi sono</a></li>
        <li><a href="/faq/">FAQ</a></li>
        <li><a href="/contatti/">Contatti</a></li>
    </ul>
</nav>

<script is:inline>
    if (document.readyState === 'complete') {
        initialize();
    } else {
        document.addEventListener('DOMContentLoaded', initialize);
    }

    function initialize() {
        const hamMenu = document.querySelector('.ham-menu');
        const hiddenMenu = document.querySelector('.hidden-menu');
        const links = document.querySelectorAll('.hidden-menu a');
        const alltabble = document.querySelectorAll('a, button, input, textarea, select, details, [tabindex]');
        const body = document.querySelector('body');

        //Disable tabbing if menu is closed
        links.forEach((link) => {
            link.setAttribute('tabIndex', '-1');
        });

        hamMenu.addEventListener('click', () => {
            const isExpanded = hamMenu.getAttribute('aria-expanded') === 'true';
            const newState = !isExpanded;

            body.classList.toggle('unscrollable');
            if (newState) {
                alltabble.forEach((tabbable) => {
                    tabbable.setAttribute('tabIndex', '-1');
                });
                links.forEach((link) => {
                    link.setAttribute('tabIndex', '0');
                });
            } else {
                alltabble.forEach((tabbable) => {
                    tabbable.setAttribute('tabIndex', '0');
                });
                links.forEach((link) => {
                    link.setAttribute('tabIndex', '-1');
                });
            }
            hamMenu.setAttribute('tabIndex', '0');

            // Update ARIA states
            hamMenu.setAttribute('aria-expanded', newState ? 'true' : 'false');
            hiddenMenu.setAttribute('aria-hidden', newState ? 'false' : 'true');

            // Toggle classes for visual state
            hamMenu.classList.toggle('active');
            hiddenMenu.classList.toggle('active');

            // If menu is now open, trap focus within it
            if (newState) {
                // Optional: focus the first link in the menu
                setTimeout(() => {
                    const firstLink = hiddenMenu.querySelector('a');
                    if (firstLink) firstLink.focus();
                }, 100);
            }
        });

        // Add keyboard support
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && hiddenMenu.classList.contains('active')) {
                // Close menu when Escape key is pressed
                hamMenu.click();
                hamMenu.focus();
            }
        });
    }
</script>

<style>
